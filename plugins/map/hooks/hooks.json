{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Verify that this grep is necessary by cross referencing with the architecture document. If the information is already in the document, respond with {'ok': 'Grep is not necessary.'} If the information is not in the document, proceed as planned.'}",
            "timeout": 120
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/check-architecture-doc.sh'",
            "async": false
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "general-purpose|Explore|Plan",
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/check-architecture-doc.sh'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/check-architecture-doc.sh'"
          },
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/record-session-baseline.sh'"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/check-architecture-doc.sh'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "Verify that the architecture document has been updated. If it has, respond with {'ok': 'Architecture document is updated.'} If it has not, respond with {'error': 'Architecture document is not updated.'}, and proceed to update the document before completing the work.",
            "statusMessage": "Checking architecture document update...",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
